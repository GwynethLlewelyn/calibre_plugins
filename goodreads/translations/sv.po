#: ..\common\common_dialogs.py:84
msgid "Keyboard shortcuts"
msgstr "Tangentbordsgenvägar"

#: ..\common\common_dialogs.py:112
msgid "Restart calibre now"
msgstr "Starta om calibre nu"

#: ..\common\common_dialogs.py:128
msgid "Preferences for:"
msgstr "Inställningar för:"

#: ..\common\common_dialogs.py:160
msgid "Clear"
msgstr "Rensa"

#: ..\common\common_dialogs.py:162
msgid "Clear all settings for this plugin"
msgstr "Rensa alla inställningar för den här insticksmodulen"

#: ..\common\common_dialogs.py:189
msgid ""
"Are you sure you want to change your settings in this library for this "
"plugin?"
msgstr ""
"Är du säker på att du vill ändra dina inställningar i det här biblioteket "
"för denna insticksmodul?"

#: ..\common\common_dialogs.py:190 ..\common\common_dialogs.py:210
msgid ""
"Any settings in other libraries or stored in a JSON file in your calibre "
"plugins folder will not be touched."
msgstr ""
"Inga inställningar i andra bibliotek eller som är sparade i en JSON-fil i "
"din calibre-insticksmodulmapp kommer att påverkas."

#: ..\common\common_dialogs.py:192 ..\common\common_dialogs.py:212
msgid "You must restart calibre afterwards."
msgstr "Du måste starta om calibre efteråt."

#: ..\common\common_dialogs.py:200
msgid "Settings changed"
msgstr "Inställningar ändrade"

#: ..\common\common_dialogs.py:201
msgid "Settings for this plugin in this library have been changed."
msgstr ""
"Inställningarna för denna insticksmodul i det här biblioteket har ändrats."

#: ..\common\common_dialogs.py:202 ..\common\common_dialogs.py:223
msgid "Please restart calibre now."
msgstr "Starta om calibre nu."

#: ..\common\common_dialogs.py:209
msgid ""
"Are you sure you want to clear your settings in this library for this "
"plugin?"
msgstr ""
"Är du säker på att du vill rensa dina inställningar i det här biblioteket "
"för den här insticksmodulen?"

#: ..\common\common_dialogs.py:221
msgid "Settings deleted"
msgstr "Inställningar borttagna"

#: ..\common\common_dialogs.py:222
msgid "All settings for this plugin in this library have been cleared."
msgstr ""
"Alla inställningar för den här insticksmodulen i det här biblioteket har "
"rensats."

#: ..\common\common_dialogs.py:297
msgid "Copy to clipboard"
msgstr "Kopiera till urklipp"

#: ..\common\common_widgets.py:105
msgid "Undefined"
msgstr "Odefinierad"

#: ..\common\common_widgets.py:160
msgid "Restart required"
msgstr "Kräver omstart"

#: ..\common\common_widgets.py:161
msgid ""
"Title image not found - you must restart Calibre before using this plugin!"
msgstr ""
"Titelbilden hittades inte - du måste starta om calibre innan du använder den"
" här insticksmodulen!"

#: ..\common\common_widgets.py:234
msgid "Create new column"
msgstr "Skapa ny kolumn"

#: config.py:154
msgid "Goodreads Genre"
msgstr "Goodreads-genre"

#: config.py:154
msgid "Maps to Calibre Tag"
msgstr "Mappas till calibre-tagg"

#: config.py:223
msgid "Goodreads genre to calibre tag mappings"
msgstr "Mappningar från Goodreads-genrer till calibre-taggar"

#: config.py:228
msgid "Filter and map genres to calibre tags"
msgstr "Filtrera och mappa genrer till calibre-taggar"

#: config.py:229
msgid ""
"When checked, only specific calibre tags will be used as per below.\n"
"When unchecked, all Goodreads genres will be added as tags."
msgstr ""
"När det här alternativet är markerat används endast de calibre-taggar som anges nedan.\n"
"När det här alternativet inte är markerat kommer alla Goodreads-genrer att läggas till som taggar."

#: config.py:242
msgid "Add genre mapping"
msgstr "Lägg till genremappning"

#: config.py:249
msgid "Delete genre mapping"
msgstr "Ta bort genremappning"

#: config.py:256
msgid "Rename Goodreads genre"
msgstr "Byt namn på Goodreads-genren"

#: config.py:263
msgid "Reset to plugin default mappings"
msgstr "Återställ till insticksmodulens standardmappningar"

#: config.py:269
msgid "Other options"
msgstr "Andra alternativ"

#: config.py:274
msgid "Scan multiple editions for title/author searches (slower)"
msgstr "Skanna flera utgåvor för titel-/författarsökningar (långsammare)"

#: config.py:275
msgid ""
"When checked will perform an additional search to scan the top ranked\n"
"Goodreads editions (if available) to exclude audiobook editions.\n"
"When unchecked you will get a faster search but the edition is indeterminate."
msgstr ""
"När det här alternativet är markerat utförs en ytterligare sökning för att skanna de högst rankade\n"
"Goodreads-utgåvorna (om tillgängliga) för att exkludera ljudboksutgåvor.\n"
"När det här alternativet är avmarkerat får du en snabbare sökning men utgåvan är obestämd."

#: config.py:281
msgid "Get all contributing authors (e.g. illustrators, series editors etc)"
msgstr ""
"Hämta alla bidragande författare (t.ex. illustratörer, serieredaktörer etc.)"

#: config.py:282
msgid ""
"When this option is checked, all authors are retrieved.\n"
"\n"
"When unchecked (default) only the primary author(s) are returned."
msgstr ""
"När det här alternativet är markerat hämtas alla författare.\n"
"\n"
"När det är avmarkerat (standard) returneras endast den/de primära författaren/författarna."

#: config.py:287
msgid "Get ASIN for kindle editions"
msgstr "Hämta ASIN för Kindle-utgåvor"

#: config.py:288
msgid ""
"When this option is checked, in cases where Goodreads has an ASIN listed\n"
"instead of an ISBN, the ASIN is retrieved. This is useful for books that\n"
"already have the specific Goodreads identifier of a Kindle editon."
msgstr ""
"När det här alternativet är markerat hämtas ASIN i de fall där Goodreads anger ett ASIN\n"
"istället för ett ISBN. Det här är användbart för böcker som\n"
"redan har det specifika Goodreads-identifieraren för en Kindle-utgåva."

#: config.py:294
msgid "Use first published date"
msgstr "Använd första utgivningsdatumet"

#: config.py:295
msgid ""
"If checked, the first published date for this book is used rather than\n"
"that of the actual book edition."
msgstr ""
"Om det här alternativet är markerat används bokens första utgivningsdatum istället för\n"
"utgivningsdatumet för den faktiska utgåvan."

#: config.py:300
msgid "Get precise rating into 'grrating' identifier"
msgstr "Hämta exakt betyg till identifieraren 'grrating'"

#: config.py:301
msgid ""
"If checked, pulls precise rating (e.g. 3.78) into an identifier\n"
"you can display as a custom column."
msgstr ""
"Om det här alternativet är markerat hämtas det exakta betyget (t.ex. 3,78) till en identifierare\n"
"som du kan visa i en anpassad kolumn."

#: config.py:306
msgid "Get #votes for rating into 'grvotes' identifier"
msgstr "Hämta antal röster för betyget till identifieraren 'grvotes'"

#: config.py:307
msgid ""
"If checked, pulls number of votes producing this rating into an identifier\n"
"you can display as a custom column."
msgstr ""
"Om det här alternativet är markerat hämtas antalet röster som ligger bakom det här betyget till en identifierare\n"
"som du kan visa i en anpassad kolumn."

#: config.py:328 config.py:359
msgid "Add new mapping"
msgstr "Lägg till ny mappning"

#: config.py:329 config.py:360
msgid "Enter a Goodreads genre name to create a mapping for:"
msgstr "Ange ett Goodreads-genrenamn för att skapa en mappning för:"

#: config.py:340
msgid "Add Failed"
msgstr "Det gick inte att lägga till"

#: config.py:340 config.py:372
msgid "A genre with the same name already exists"
msgstr "En genre med samma namn finns redan"

#: config.py:348 config.py:379
msgid "Are you sure?"
msgstr "Är du säker?"

#: config.py:349
msgid "Are you sure you want to delete the selected genre mappings?"
msgstr "Är du säker på att du vill ta bort de valda genremappningarna?"

#: config.py:372
msgid "Rename Failed"
msgstr "Namnbyte misslyckades"

#: config.py:380
msgid "Are you sure you want to reset to the plugin default genre mappings?"
msgstr ""
"Är du säker på att du vill återställa insticksmodulens standardmappningar "
"för genrer?"
